# Debugg Dashboard Configuration
# Copy this file to .env and update values

# ==================== Server ====================
PORT=3001
NODE_ENV=production

# ==================== Database ====================
# For PostgreSQL (Production)
DATABASE_URL="postgresql://debugg:debugg_secret@localhost:5432/debugg?schema=public"

# For SQLite (Development)
# DATABASE_URL="file:./dev.db"

# Database credentials
DB_USER=debugg
DB_PASSWORD=debugg_secret_change_this
DB_PORT=5432

# ==================== Security ====================
# Generate a secure API key for dashboard access
# openssl rand -hex 32
DASHBOARD_API_KEY=your_secure_api_key_here

# Session secret
SESSION_SECRET=your_session_secret_here

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3001,https://your-domain.com

# ==================== Authentication ====================
# Enable basic authentication
ENABLE_AUTH=false

# Admin credentials (change in production!)
ADMIN_EMAIL=admin@debugg.local
ADMIN_PASSWORD=change_this_password

# ==================== Email (Optional) ====================
# For email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@debugg.local

# ==================== Slack Integration (Optional) ====================
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#errors

# ==================== Monitoring ====================
# Sentry for error tracking (optional)
SENTRY_DSN=

# ==================== Feature Flags ====================
ENABLE_ERROR_GROUPING=true
ENABLE_AUTO_REFRESH=true
ENABLE_EXPORT=true
ENABLE_COMMENTS=false

# ==================== Performance ====================
# Auto-refresh interval (milliseconds)
AUTO_REFRESH_INTERVAL=30000

# Pagination default
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== Storage ====================
# Maximum errors to keep (0 = unlimited)
MAX_ERRORS=0

# Error retention days (0 = forever)
ERROR_RETENTION_DAYS=0

# ==================== Backup ====================
# Automatic backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *
BACKUP_DIR=/app/backups

# ==================== Logging ====================
LOG_LEVEL=info
LOG_FILE=/app/logs/dashboard.log
LOG_MAX_SIZE=10MB
LOG_MAX_FILES=5

# ==================== SSL/TLS (Optional) ====================
# For HTTPS
SSL_ENABLED=false
SSL_CERT_PATH=/app/ssl/cert.pem
SSL_KEY_PATH=/app/ssl/key.pem

# ==================== Deployment ====================
# Docker
DOCKER_ENABLED=true

# Kubernetes (if using K8s)
KUBERNETES_ENABLED=false

# ==================== External Services ====================
# For cloud deployments
REDIS_URL=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
