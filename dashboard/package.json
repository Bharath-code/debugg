{
  "name": "debugg-dashboard",
  "version": "2.0.0",
  "description": "Debugg Dashboard - Production-ready error monitoring",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch dashboard/server.ts",
    "start": "bun run dashboard/server.ts",
    "build": "tsc",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "bun run dashboard/database/seed.ts",
    "docker:build": "docker build -t debugg-dashboard .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/socket.io": "^3.0.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "express": "^4.18.2",
    "ioredis": "^5.9.3",
    "nodemailer": "^8.0.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cookie-parser": "^1.4.6",
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "prisma": "^5.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "error-monitoring",
    "dashboard",
    "debugging",
    "typescript"
  ],
  "author": "Bharath",
  "license": "MIT"
}
