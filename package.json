{
  "name": "debugg",
  "version": "1.0.0",
  "description": "Debugg - Smart Error Handling for Developers. A comprehensive, cross-platform error handling and monitoring library that makes debugging enjoyable.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:ts": "tsc",
    "dev": "tsup --watch",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "docs": "typedoc src/index.ts --out docs/api"
  },
  "keywords": [
    "error",
    "handling",
    "monitoring",
    "logging",
    "exception",
    "cross-platform",
    "typescript",
    "javascript",
    "bun",
    "performance",
    "debugging"
  ],
  "author": "Bharath",
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@sentry/node": "^10.32.1",
    "@types/bun": "^1.3.5",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.27",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "next": "^16.1.1",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.2",
    "tsup": "^8.0.0",
    "typedoc": "^0.25.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.6.7"
  },
  "peerDependencies": {
    "@sentry/node": ">=10.0.0"
  },
  "peerDependenciesMeta": {
    "@sentry/node": {
      "optional": true
    }
  },
  "sideEffects": false,
  "bun": {
    "runtime": "bun"
  }
}
