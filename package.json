{
  "name": "debugg",
  "version": "1.0.0",
  "description": "Debugg - Smart Error Handling for Developers. A comprehensive, cross-platform error handling and monitoring library that makes debugging enjoyable.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "build:ts": "tsc",
    "build:analyze": "bun run build:size",
    "build:size": "node scripts/bundle-size.js",
    "build:verify": "node scripts/verify-tree-shaking.js",
    "dev": "tsup --watch",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "test:integration": "bun test tests/integration",
    "test:e2e": "bun test tests/e2e",
    "test:performance": "bun test tests/performance",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "docs": "typedoc src/index.ts --out docs/api",
    "docs:watch": "typedoc src/index.ts --out docs/api --watch",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "version": "node scripts/version.js",
    "prepublishOnly": "bun run build && bun test",
    "postpublish": "node scripts/post-publish.js"
  },
  "keywords": [
    "error",
    "handling",
    "monitoring",
    "logging",
    "exception",
    "cross-platform",
    "typescript",
    "javascript",
    "bun",
    "performance",
    "debugging",
    "sentry",
    "reporting"
  ],
  "author": "Bharath",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/debugg.git"
  },
  "homepage": "https://github.com/your-org/debugg#readme",
  "bugs": {
    "url": "https://github.com/your-org/debugg/issues"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@sentry/node": "^10.32.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.0.0",
    "@semantic-release/npm": "^12.0.0",
    "@types/bun": "^1.3.5",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.27",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.0",
    "gzip-size": "^7.0.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "next": "^16.1.1",
    "prettier": "^3.2.0",
    "semantic-release": "^23.0.0",
    "terser": "^5.27.0",
    "ts-jest": "^29.1.2",
    "tsup": "^8.0.0",
    "typedoc": "^0.25.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.6.7"
  },
  "peerDependencies": {
    "@sentry/node": ">=10.0.0"
  },
  "peerDependenciesMeta": {
    "@sentry/node": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
